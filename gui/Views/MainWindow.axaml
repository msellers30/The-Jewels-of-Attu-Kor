<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Game.Gui.ViewModels"
        x:Class="Game.Gui.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1400" Height="526"
        MinWidth="560" MinHeight="400"
        Title="The Jewels of Attu-Kor">

    <DockPanel>

        <!-- Toolbar: runtime layout picker -->
        <Border DockPanel.Dock="Top" Padding="10,8" Background="#22FFFFFF">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Layout:" VerticalAlignment="Center" />
                <ComboBox MinWidth="150"
                          ItemsSource="{Binding Layouts}"
                          SelectedItem="{Binding SelectedLayout}" />
            </StackPanel>
        </Border>

        <!-- Main area. Image + transcript are placed in a proportional (star-sized) grid; code-behind
             (ApplyLayout) sets the rows/columns per SelectedLayout, so the image is a percentage of the
             window and resizes with it. -->
        <Grid x:Name="MainArea" Margin="10">

            <Border x:Name="ImagePanel"
                    BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="6"
                    Background="#10FFFFFF">
                <Panel>
                    <Image Source="{Binding RoomImage}" IsVisible="{Binding HasImage}"
                           Stretch="Uniform" VerticalAlignment="Top" Margin="6" />
                    <Border IsVisible="{Binding !HasImage}" Padding="16">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                            <TextBlock Text="🖼" FontSize="52" Opacity="0.4" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding RoomPlaceholder}" FontSize="18" FontWeight="SemiBold"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                            <TextBlock Text="(no image yet)" Opacity="0.5" FontSize="12"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Panel>
            </Border>

            <Grid x:Name="ContentPanel" RowDefinitions="*,Auto">
                <ScrollViewer x:Name="TranscriptScroller" Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <SelectableTextBlock x:Name="TranscriptText"
                                         Text="{Binding Transcript}"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas, Menlo, monospace"
                                         Padding="6" />
                </ScrollViewer>

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                    <TextBox x:Name="InputBox" Grid.Column="0"
                             Text="{Binding Input}"
                             Watermark="Type a command…"
                             IsEnabled="{Binding IsInputEnabled}" />
                    <Button x:Name="SendButton" Grid.Column="1" Content="Send"
                            IsDefault="True" Margin="8,0,0,0"
                            Click="OnSubmit"
                            IsEnabled="{Binding IsInputEnabled}" />
                </Grid>
            </Grid>

        </Grid>
    </DockPanel>
</Window>
